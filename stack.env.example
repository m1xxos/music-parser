# Music Parser environment variables
# Copy this file to stack.env and adjust for your setup.

# Host folder mounted to /music in container (Navidrome can read this folder)
MUSIC_DIR=./music

# Host folder mounted to /omnivore/inbox in container (Omnivore folder import)
OMNIVORE_IMPORT_HOST_DIR=./omnivore/inbox

# In-container target directories
OUTPUT_DIR=/music
OMNIVORE_IMPORT_DIR=/omnivore/inbox
